# Copie para .env e preencha. Segredos (NEXUS_API_KEY, SESSION_SECRET) ficam fora do git.
DATABASE_URL="postgresql://consultoria:SENHA@localhost:5432/consultoria_plus?schema=public"

NEXUS_BASE_URL="http://192.168.0.75:3001"
NEXUS_API_KEY="<api_key gerada no cadastro do sistema em systems>"
NEXUS_SYSTEM_ID="<systems.id deste sistema>"
NEXUS_PORTAL_URL="https://nexus.grupoitamarathy.local/portal"

APP_URL="https://consultoria.grupoitamarathy.local"
SESSION_SECRET="<openssl rand -hex 32>"

CONSULTOR_DEPARTMENTS="Consultoria"
DUAL_VIEW_DEPARTMENTS="Diretoria"
ADMIN_CARGOS="Administrador"

DEV_LOGIN="false"
